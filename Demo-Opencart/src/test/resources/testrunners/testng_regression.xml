<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OpenCart Regression Test Automation Suite" verbose="4"
	thread-count="4" parallel="tests">
	<listeners>
		<listener class-name="com.qa.opencart.listeners.ExtentReportListener"></listener>
	</listeners>
	<test name="Open Cart Home page test">
		<classes>
			<class name="com.qa.opencart.tests.HomePageTest" />
		</classes>
	</test>
	<test name="Open Cart Login page test">
		<classes>
			<class name="com.qa.opencart.tests.LoginPageTest" />
		</classes>
	</test>

</suite>
